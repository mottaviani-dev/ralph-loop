{
  "model": "sonnet",
  "timeout": 600,
  "skip_commit": true,
  "max_discovery_cycles": 0,
  "max_consecutive_failures": 3,
  "max_stale_cycles": 5,
  "discovery_only": true,
  "use_agents": true,
  "journal_keep_lines": 300,
  "enable_mcp": false,
  "verbose_cleanup": false,
  "notify": {
    "on": ["complete", "error"]
  }
}
