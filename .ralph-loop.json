{
  "model": "opus",
  "timeout": 900,
  "skip_commit": false,
  "max_work_cycles": 100,
  "max_discovery_cycles": 0,
  "max_consecutive_failures": 10,
  "max_stale_cycles": 100,
  "max_empty_task_cycles": 100,
  "validate_before_commit": false,
  "use_agents": false,
  "discovery_only": false,
  "journal_keep_lines": 500,
  "enable_mcp": false,
  "verbose_cleanup": false,
  "notify": {
    "on": ["complete", "error"]
  },
  "git_exclude": []
}
